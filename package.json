{
  "name": "wt-records",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed-run.ts",
    "catalog:sync": "bun run src/catalog/sync-run.ts",
    "import:extract": "bun run src/migration/extract-run.ts",
    "import:resolve": "bun run src/migration/resolve-run.ts",
    "import:load": "bun run src/migration/load-run.ts",
    "import:reset": "bun run src/migration/reset-run.ts",
    "r2:verify": "bun run src/storage/r2-verify.ts",
    "og:embed": "bun run scripts/og-embed-assets.ts",
    "og:fallback": "bun run og:embed && bun run scripts/og-generate-fallback.tsx && bun run og:embed",
    "og:preview": "bun run scripts/og-preview.tsx",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node ./.output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "bun run build && playwright test",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:merge-reports": "playwright merge-reports --reporter html",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1083.0",
    "@aws-sdk/s3-request-presigner": "3.1083.0",
    "@sentry/react": "10.63.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "2.110.2",
    "@tailwindcss/vite": "4.3.1",
    "@takumi-rs/image-response": "2.4.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/router-plugin": "1.168.18",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.545.0",
    "nitro": "3.0.260610-beta",
    "postgres": "^3.4.9",
    "posthog-js": "1.396.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3",
    "srvx": "0.11.17",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.3",
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.17",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "jsdom": "28.1.0",
    "prettier": "3.9.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "unrs-resolver"
  ]
}

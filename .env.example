# Copy to .env and fill in. Never commit real secrets.

# ---- Client (public, VITE_-prefixed — bundled into the browser) ----
# Observability (PRD §5). Absent keys leave the SDKs inert. On Railway these are
# build-time vars (Vite inlines them) — see Dockerfile. PostHog rides a shared
# project tagged `app: wt-records`; analytics + replay wait for consent.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---- Server (secrets — consumed starting PR2/PR3, never exposed to the client) ----
# Local Supabase defaults (from `supabase start`); override per environment.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_DSN=

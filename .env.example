# Copy to .env and fill in. Never commit real secrets.

# ---- Client (public, VITE_-prefixed — bundled into the browser) ----
# Observability. Absent keys leave the SDKs inert. On Railway these are
# build-time vars (Vite inlines them) — see Dockerfile. PostHog rides a shared
# project tagged `app: wt-records`; analytics + replay wait for consent.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Realtime live feed. The anon key is public by design — RLS exposes only
# verified+current records to it, and the browser client is Realtime-only.
# Absent keys degrade silently to the static SSR site. Local values from
# `bunx supabase status`.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ---- Server (secrets — never exposed to the client) ----
# Local Supabase defaults (from `supabase start`); override per environment.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_DSN=

# Cloudflare R2 proof/asset storage (S3-compatible). Token is scoped to the
# three buckets; endpoint is https://<account-id>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=wt-records-proofs
R2_BUCKET_PENDING=wt-records-proofs-pending
R2_BUCKET_ASSETS=wt-records-assets
R2_PUBLIC_BASE_URL=https://proofs.wtrecords.gg
R2_ASSETS_BASE_URL=https://assets.wtrecords.gg

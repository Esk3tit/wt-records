{
  "$schema": "https://raw.githubusercontent.com/promptarmor/kstack/master/no-mistakes/config/no-mistakes.schema.json",
  "project": "wt-records",
  "db": {
    "platform": "supabase",
    "adapter": "sql",
    "previewBranchPattern": "preview-{pr}",
    "connStringEnv": "NMB_DATABASE_URL",
    "mcp": {
      "server": "Supabase",
      "runSql": "execute_sql",
      "describeBranch": "get_branch",
      "getConnectionString": "get_connection_string"
    }
  },
  "org": "Esk3tit",
  "repoOwner": "Esk3tit",
  "checkoutBase": "/Users/khaiphan/code",
  "evidence": {
    "backend": "git-branch"
  },
  "auth": {
    "profiles": {
      "supabase": {
        "kind": "supabase-jwt",
        "secretsTool": "dotenv",
        "env": {
          "url": "SUPABASE_URL",
          "anonKey": "SUPABASE_ANON_KEY",
          "serviceKey": "SUPABASE_SERVICE_ROLE_KEY"
        },
        "testEmailEnv": "TEST_USER_EMAIL"
      }
    }
  },
  "apps": [
    {
      "name": "wt-records",
      "kind": "backend",
      "repo": "Esk3tit/wt-records",
      "devUrl": "http://localhost:3000",
      "auth": "supabase"
    }
  ]
}

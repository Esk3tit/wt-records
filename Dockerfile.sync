# Catalog-sync cron image: a short-lived Bun script with no server, so the
# repo's Node-runtime-for-servers rule doesn't apply. Syncs and exits.
FROM oven/bun:1.3.14-slim
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile --production
COPY tsconfig.json ./
COPY src ./src
USER bun
# The cron service is the one place remote syncs are deliberate.
ENV CATALOG_SYNC_REMOTE=1
CMD ["bun", "run", "src/catalog/sync-run.ts"]
